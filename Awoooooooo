local Toggle = VTab:CreateToggle({
	Name = "Wolf ESP",
	CurrentValue = false,
	Flag = "WolfESPAuto",

	Callback = function(Value)
		local function AddESP(model)
			if model:IsA("Model") and model:FindFirstChild("WolfTag") then
				if not model:FindFirstChild("WolfESP") then
					local Highlight = Instance.new("Highlight")
					Highlight.Name = "WolfESP"
					Highlight.Adornee = model
					Highlight.FillTransparency = 1
					Highlight.OutlineColor = Color3.fromRGB(255, 0, 0)
					Highlight.OutlineTransparency = 0
					Highlight.Parent = model
				end
			end
		end

		if Value then
			-- Models que já existem
			for _, model in ipairs(workspace:GetChildren()) do
				AddESP(model)
			end

			-- Models que aparecerem depois
			Connection = workspace.ChildAdded:Connect(function(child)
				AddESP(child)
			end)
		else
			if Connection then
				Connection:Disconnect()
				Connection = nil
			end

			-- Remove todos os ESPs
			for _, obj in ipairs(workspace:GetDescendants()) do
				if obj.Name == "WolfESP" and obj:IsA("Highlight") then
					obj:Destroy()
				end
			end
		end
	end,
})

