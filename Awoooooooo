-- ==================== FUNÇÕES ====================
local function getHumanoid()
    local character = player.Character or player.CharacterAdded:Wait()
    humanoid = character:WaitForChild("Humanoid")
    return humanoid
end

local function findTarget()
    local wolfTag = workspace:FindFirstChild(TAG_NAME, true)
    if wolfTag then
        return wolfTag.Parent
    end
    return nil
end

local function teleportBehindTarget(target)
    local wolfTag = target:FindFirstChild(TAG_NAME)
    if not wolfTag then return false end

    local targetCFrame = wolfTag.CFrame
    -- Calcula posição atrás do alvo
    local behindOffset = targetCFrame.LookVector * -TELEPORT_DISTANCE
    local behindPosition = targetCFrame.Position + behindOffset + Vector3.new(0, 3, 0) -- um pouco acima

    local character = player.Character
    if character and character:FindFirstChild("HumanoidRootPart") then
        character.HumanoidRootPart.CFrame = CFrame.new(behindPosition) * CFrame.lookAt(behindPosition, targetCFrame.Position)
        return true
    end
    return false
end

local function fireArrow(direction, startPos)
    local arrowTemplate = tool:FindFirstChild("Arrow")
    if not arrowTemplate then
        warn("❌ Model 'Flecha' não encontrado dentro da Tool!")
        return
    end

    local arrow = arrowTemplate:Clone()
    arrow.Parent = workspace
    arrow:PivotTo(CFrame.new(startPos) * CFrame.lookAt(Vector3.new(0,0,0), direction))

    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(4000, 4000, 4000)
    bv.Velocity = direction * 120
    bv.Parent = arrow

    game.Debris:AddItem(arrow, 6)
end

local function shootAtTarget()
    if not canShoot then return end
    canShoot = false

    -- Equipa a Tool
    local hum = getHumanoid()
    if tool.Parent ~= hum.Parent then
        hum:EquipTool(tool)
        task.Wait(0.2)
    end

    local target = findTarget()
    if not target then
        print("❌ WolfTag não encontrado!")
        canShoot = true
        return
    end

    -- Teleporta para trás do alvo
    local teleported = teleportBehindTarget(target)
    if not teleported then
        warn("Falha ao teleportar!")
    end

    task.Wait(0.15) -- pequeno delay após teleport

    -- Atira
    local wolfTag = target:FindFirstChild(TAG_NAME)
    local targetPos = wolfTag.Position

    local handle = tool:FindFirstChild("Handle") or tool.PrimaryPart
    if not handle then 
        canShoot = true
        return 
    end

    local startPos = handle.Position
    local direction = (targetPos - startPos).Unit

    fireArrow(direction, startPos)

    task.Wait(COOLDOWN)
    canShoot = true
end

-- ==================== CONEXÕES ====================
autoAimButton.MouseButton1Click:Connect(shootAtTarget)

