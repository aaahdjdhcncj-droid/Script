local Button = ITab:CreateButton({
	Name = "Auto Get Crossbow",
	Callback = function()
		local Player = game.Players.LocalPlayer
		local Character = Player.Character
		local Root = Character and Character:FindFirstChild("HumanoidRootPart")

		if not Root then
			return
		end

		local OldCFrame = Root.CFrame

		local EffectsBin = workspace:FindFirstChild("EffectsBin")
		if not EffectsBin then
			return
		end

		for _, obj in ipairs(EffectsBin:GetChildren()) do
			if obj.Name == "Handle" and obj:IsA("BasePart") then
				-- Vai até a Crossbow
				Root.CFrame = obj.CFrame + Vector3.new(0, 1, 0)

				-- Espera pegar o item
				task.wait(0.30)

				-- Volta para a posição original
				Root.CFrame = OldCFrame
				break
			end
		end
	end,
})

