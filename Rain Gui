-- ============================================================
-- LÓGICA DE CLIMA (RemoteEvent ou Lighting local)
-- ============================================================
-- Nota: Para funcionar em servidor multiplayer, use RemoteEvents.
-- Esta versão altera o Lighting localmente para demonstração.

local rain = nil
local currentWeather = "none"

local function setStatus(text, color)
	statusLabel.Text = text
	statusLabel.TextColor3 = color or Color3.fromRGB(160, 160, 160)
end

local function stopRain()
	-- Remove partículas de chuva se existirem
	local existing = workspace:FindFirstChild("RainPart")
	if existing then existing:Destroy() end
	currentWeather = "none"
end

local function startRain(withLightning)
	stopRain()

	-- Configura o Lighting para clima chuvoso
	Lighting.Brightness = 0.4
	Lighting.ClockTime = 14
	Lighting.Ambient = Color3.fromRGB(80, 80, 100)
	Lighting.OutdoorAmbient = Color3.fromRGB(60, 60, 80)
	Lighting.FogEnd = 800
	Lighting.FogColor = Color3.fromRGB(140, 140, 150)

	-- Cria a partícula de chuva
	local rainPart = Instance.new("Part")
	rainPart.Name = "RainPart"
	rainPart.Anchored = true
	rainPart.CanCollide = false
	rainPart.Transparency = 1
	rainPart.Size = Vector3.new(1, 1, 1)
	rainPart.CFrame = CFrame.new(0, 300, 0)
	rainPart.Parent = workspace

	local emitter = Instance.new("ParticleEmitter")
	emitter.Texture = "rbxassetid://6101261910"
	emitter.Rate = 600
	emitter.Speed = NumberRange.new(100, 130)
	emitter.Lifetime = NumberRange.new(2, 3)
	emitter.SpreadAngle = Vector2.new(0, 0)
	emitter.Size = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0.05),
		NumberSequenceKeypoint.new(1, 0.05)
	})
	emitter.Transparency = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0.3),
		NumberSequenceKeypoint.new(1, 0.8)
	})
	emitter.LightEmission = 0
	emitter.Color = ColorSequence.new(Color3.fromRGB(180, 200, 220))
	emitter.Rotation = NumberRange.new(90, 90)
	emitter.EmissionDirection = Enum.NormalId.Front
	emitter.VelocitySpread = 5
	emitter.Parent = rainPart

	-- Segue o jogador
	local char = player.Character or player.CharacterAdded:Wait()
	RunService.Heartbeat:Connect(function()
		if rainPart and rainPart.Parent then
			local rootPart = char:FindFirstChild("HumanoidRootPart")
			if rootPart then
				rainPart.CFrame = CFrame.new(rootPart.Position + Vector3.new(0, 60, 0))
			end
		end
	end)

	-- Raios (se withLightning)
	if withLightning then
		currentWeather = "storm"
		local lightningTask
		lightningTask = task.spawn(function()
			while currentWeather == "storm" do
				task.wait(randomFloat(3, 8))
				if currentWeather ~= "storm" then break end
				-- Flash
				local sky = Lighting:FindFirstChildOfClass("Sky")
				local origBrightness = Lighting.Brightness
				TweenService:Create(Lighting, TweenInfo.new(0.05), {Brightness = 3}):Play()
				task.wait(0.05)
				TweenService:Create(Lighting, TweenInfo.new(0.08), {Brightness = origBrightness}):Play()
				task.wait(0.08)
				TweenService:Create(Lighting, TweenInfo.new(0.04), {Brightness = 2.5}):Play()
				task.wait(0.04)
				TweenService:Create(Lighting, TweenInfo.new(0.1), {Brightness = origBrightness}):Play()

				-- Som de trovão (opcional, necessita SoundService)
				-- local thunder = Instance.new("Sound")
				-- thunder.SoundId = "rbxassetid://1369158" 
				-- thunder.Parent = workspace
				-- thunder:Play()
				-- game:GetService("Debris"):AddItem(thunder, 5)
			end
		end)
	else
		currentWeather = "rain"
	end
end

local function clearWeather()
	stopRain()
	TweenService:Create(Lighting, TweenInfo.new(2), {
		Brightness = 2,
		Ambient = Color3.fromRGB(127, 127, 127),
		OutdoorAmbient = Color3.fromRGB(127, 127, 127),
		FogEnd = 100000,
	}):Play()
	Lighting.ClockTime = 14
end

