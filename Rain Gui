-- ============================================================
-- BOLAS ANIMADAS
-- ============================================================
local balls = {}

local function randomFloat(min, max)
	return min + math.random() * (max - min)
end

for i = 1, NUM_BALLS do
	local size = randomFloat(BALL_MIN_SIZE, BALL_MAX_SIZE)
	local ball = Instance.new("Frame")
	ball.Size = UDim2.new(0, size, 0, size)
	ball.Position = UDim2.new(randomFloat(0, 0.9), 0, randomFloat(0, 0.9), 0)
	ball.BackgroundColor3 = (math.random() > 0.5)
		and Color3.fromRGB(255, 255, 255)
		or  Color3.fromRGB(40, 40, 40)
	ball.BackgroundTransparency = randomFloat(0.3, 0.7)
	ball.BorderSizePixel = 0
	ball.ZIndex = 2
	ball.Parent = ballCanvas

	local ballCorner = Instance.new("UICorner")
	ballCorner.CornerRadius = UDim.new(1, 0)
	ballCorner.Parent = ball

	balls[i] = {
		frame = ball,
		vx = randomFloat(-0.06, 0.06),
		vy = randomFloat(-0.06, 0.06),
		px = randomFloat(0, 1),
		py = randomFloat(0, 1),
	}
end

-- Loop de animação das bolas
RunService.Heartbeat:Connect(function(dt)
	for _, b in ipairs(balls) do
		b.px = b.px + b.vx * dt
		b.py = b.py + b.vy * dt

		if b.px < 0 then b.px = 0; b.vx = math.abs(b.vx) end
		if b.py < 0 then b.py = 0; b.vy = math.abs(b.vy) end
		if b.px > 0.92 then b.px = 0.92; b.vx = -math.abs(b.vx) end
		if b.py > 0.92 then b.py = 0.92; b.vy = -math.abs(b.vy) end

		b.frame.Position = UDim2.new(b.px, 0, b.py, 0)
	end
end)

-- ============================================================
-- ARRASTAR GUI
-- ============================================================
local dragging = false
local dragInput, dragStart, startPos

titleBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or
	   input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = mainFrame.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

titleBar.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or
	   input.UserInputType == Enum.UserInputType.Touch then
		dragInput = input
	end
end)

game:GetService("UserInputService").InputChanged:Connect(function(input)
	if input == dragInput and dragging then
		local delta = input.Position - dragStart
		mainFrame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

