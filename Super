-- ========================
--    WALL CHECK (Raycast)
-- ========================
local function HasLineOfSight(bone)
	local origin    = Camera.CFrame.Position
	local target    = bone.Position
	local direction = target - origin

	local ignoreList = {}
	local localChar = LocalPlayer.Character
	if localChar then
		for _, v in ipairs(localChar:GetDescendants()) do
			if v:IsA("BasePart") then table.insert(ignoreList, v) end
		end
	end
	local boneChar = bone.Parent
	if boneChar then
		for _, v in ipairs(boneChar:GetDescendants()) do
			if v:IsA("BasePart") then table.insert(ignoreList, v) end
		end
	end

	local params = RaycastParams.new()
	params.FilterDescendantsInstances = ignoreList
	params.FilterType = Enum.RaycastFilterType.Exclude

	return workspace:Raycast(origin, direction, params) == nil
end

-- ========================
--    AIMBOT
-- ========================
local function GetTarget()
	local MousePos = UserInputService:GetMouseLocation()
	local Best, BestDist = nil, S.FOV

	for _, p in ipairs(Players:GetPlayers()) do
		if p == LocalPlayer then continue end
		if S.TeamCheck and IsSameTeam(p) then continue end

		local char = p.Character
		if not char then continue end
		local hum  = char:FindFirstChild("Humanoid")
		local bone = char:FindFirstChild(S.Bone) or char:FindFirstChild("Head")
		if not hum or not bone then continue end
		if hum.Health <= 0 then continue end
		if S.WalkCheck and hum.MoveDirection.Magnitude < 0.1 then continue end

		local sp = Camera:WorldToViewportPoint(bone.Position)
		if sp.Z <= 0 then continue end

		if S.WallCheck and not HasLineOfSight(bone) then continue end

		local dist2D = (Vector2.new(sp.X, sp.Y) - MousePos).Magnitude
		if dist2D < BestDist then
			BestDist = dist2D
			Best = bone
		end
	end

	return Best
end

-- ========================
--      RENDER LOOP
-- ========================
RunService.RenderStepped:Connect(function(dt)
	if Circle.Visible then
		Circle.Position = UserInputService:GetMouseLocation()
	end

	if S.AimbotEnabled then
		local bone = GetTarget()
		if bone then
			local sp = Camera:WorldToViewportPoint(bone.Position)
			local ray = Camera:ViewportPointToRay(sp.X, sp.Y)
			local targetPos = ray.Origin + ray.Direction * 500
			local currentCF = Camera.CFrame
			local goalCF = CFrame.new(currentCF.Position, targetPos)
			local alpha = math.clamp(dt * (30 / S.Smoothing), 0, 1)
			Camera.CFrame = currentCF:Lerp(goalCF, alpha)
		end
	end

	for _, p in ipairs(Players:GetPlayers()) do
		if p == LocalPlayer then continue end
		local show = ShouldShowESP(p)
		local has  = Highlights[p] ~= nil
		if show and not has then
			ApplyHighlight(p)
		elseif not show and has then
			RemoveHighlight(p)
		end
	end
end)

