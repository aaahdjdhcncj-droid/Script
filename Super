-- ========================
--    HIGHLIGHT ESP
-- ========================
local Highlights = {}

local function IsSameTeam(p)
	return LocalPlayer.Team ~= nil and p.Team == LocalPlayer.Team
end

local function ShouldShowESP(player)
	if not S.ESPEnabled then return false end
	if S.ESPTeamCheck and IsSameTeam(player) then return false end
	local lc = LocalPlayer.Character
	local lr = lc and lc:FindFirstChild("HumanoidRootPart")
	local pc = player.Character
	local pr = pc and pc:FindFirstChild("HumanoidRootPart")
	if not lr or not pr then return false end
	if (pr.Position - lr.Position).Magnitude > S.ESPMaxDist then return false end
	return true
end

local function ApplyHighlight(player)
	if Highlights[player] then
		Highlights[player]:Destroy()
		Highlights[player] = nil
	end
	if not ShouldShowESP(player) then return end
	local c = player.Character
	if not c then return end

	local h = Instance.new("Highlight")
	h.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
	h.FillTransparency    = 0.5
	h.OutlineTransparency = 0
	h.FillColor           = IsSameTeam(player)
		and Color3.fromRGB(50, 150, 255)
		or  Color3.fromRGB(255, 50, 50)
	h.OutlineColor        = Color3.fromRGB(255, 255, 255)
	h.Parent              = c
	Highlights[player]    = h
end

local function RemoveHighlight(player)
	if Highlights[player] then
		Highlights[player]:Destroy()
		Highlights[player] = nil
	end
end

local function UpdateAllESP()
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LocalPlayer then ApplyHighlight(p) end
	end
end

local function SetupPlayer(player)
	player.CharacterAdded:Connect(function()
		task.wait(0.5)
		ApplyHighlight(player)
	end)
	if player.Character then ApplyHighlight(player) end
end

for _, p in ipairs(Players:GetPlayers()) do
	if p ~= LocalPlayer then SetupPlayer(p) end
end
Players.PlayerAdded:Connect(SetupPlayer)
Players.PlayerRemoving:Connect(RemoveHighlight)

