local KEYWORD  = "Grandma"  -- nome do modelo
local INTERVAL = 0.1        -- segundos entre cada teleporte
local OFFSET   = Vector3.new(0, 5, 0)  -- altura acima da Grandma
-- =====================================================

local isActive   = false
local loopThread = nil

-- Caminho
local SpawnedNPCs = workspace:WaitForChild("SpawnedNPCs")

-- =====================================================
-- HELPERS
