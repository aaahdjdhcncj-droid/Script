local cookieActive = false
local cookieThread = nil

local function getSpawnedItems()
   local ok, result = pcall(function()
      return workspace:WaitForChild("Map", 5)
         :WaitForChild("Functional", 5)
         :WaitForChild("SpawnedItems", 5)
   end)
   return ok and result or nil
end

local function getPrompt(cookie)
   for _, child in ipairs(cookie:GetDescendants()) do
      if child:IsA("ProximityPrompt") then return child end
   end
   return nil
end

local ToggleAutoCookies = MTab:CreateToggle({
   Name = "Auto Cookies",
   CurrentValue = false,
   Flag = "Toggle_AutoCookies",
   Callback = function(Value)
      if Value then
         local SpawnedItems = getSpawnedItems()
         if not SpawnedItems then
            print("[AutoCookies] âš ï¸ SpawnedItems nÃ£o encontrado!")
            return
         end
         cookieActive = true
         cookieThread = task.spawn(function()
            while cookieActive do
               local char = player.Character
               local root = char and char:FindFirstChild("HumanoidRootPart")
               if not root then task.wait(0.5) continue end

               local list = {}
               for _, item in ipairs(SpawnedItems:GetChildren()) do
                  if item:IsA("Model") and string.find(item.Name, "CookieObject") then
                     table.insert(list, item)
                  end
               end

               if #list == 0 then
                  task.wait(0.5)
               else
                  for _, cookie in ipairs(list) do
                     if not cookieActive then break end
                     local prompt = getPrompt(cookie)
                     if prompt then
                        local part = cookie.PrimaryPart or cookie:FindFirstChildOfClass("BasePart")
                        if part then
                           -- Teleporta o player DENTRO do cookie
                           root.CFrame = part.CFrame
                           task.wait(0.08)
                           fireproximityprompt(prompt)
                           task.wait(0.08)
                        end
                     end
                  end
               end
            end
         end)
      else
         cookieActive = false
         if cookieThread then task.cancel(cookieThread) cookieThread = nil end
      end
   end,
})

player.CharacterAdded:Connect(function()
   if cookieActive then
      cookieActive = false
      if cookieThread then task.cancel(cookieThread) cookieThread = nil end
      ToggleAutoCookies:Set(false)
   end
end)

