-- Key ESP (Tool Toggle)
local player_esp    = Players.LocalPlayer
local character_esp = player_esp.Character or player_esp.CharacterAdded:Wait()
local humanoid_esp  = character_esp:WaitForChild("Humanoid")
local backpack_esp  = player_esp:WaitForChild("Backpack")

local toolLooping  = false
local toolThread   = nil

local function getCurrentTool()
   for _, item in ipairs(character_esp:GetChildren()) do
      if item:IsA("Tool") then return item end
   end
   return nil
end

local function getBackpackTool()
   return backpack_esp:FindFirstChildOfClass("Tool")
end

local ToggleKeyEsp = ETab:CreateToggle({ -- CORRIGIDO: flag única, sem CreateToggle duplicado interno
   Name = "Key Esp",
   CurrentValue = false,
   Flag = "Toggle_KeyEsp",
   Callback = function(Value)
      if Value then
         local tool = getCurrentTool() or getBackpackTool()
         if not tool then
            print("[ToggleTool] ⚠️ Nenhum Tool disponível!")
            return
         end
         toolLooping = true
         toolThread = task.spawn(function()
            while toolLooping do
               if getCurrentTool() then
                  humanoid_esp:UnequipTools()
               else
                  local toEquip = getBackpackTool()
                  if toEquip then humanoid_esp:EquipTool(toEquip) end
               end
               task.wait(0.08)
            end
         end)
      else
         toolLooping = false
         if toolThread then task.cancel(toolThread) toolThread = nil end
         humanoid_esp:UnequipTools()
      end
   end,
})

player_esp.CharacterAdded:Connect(function(newChar)
   if toolLooping then
      toolLooping = false
      if toolThread then task.cancel(toolThread) toolThread = nil end
      ToggleKeyEsp:Set(false)
   end
   character_esp = newChar
   humanoid_esp  = newChar:WaitForChild("Humanoid")
end)

-- Cookie ESP (Highlight)
local espActive    = false
local espConns     = {}

local Map_e          = workspace:WaitForChild("Map")
local Functional_e   = Map_e:WaitForChild("Functional")
local SpawnedItems_e = Functional_e:WaitForChild("SpawnedItems")

local function applyHighlight(model)
   if model:FindFirstChild("CookieHighlight") then return end
   local h = Instance.new("Highlight")
   h.Name                = "CookieHighlight"
   h.FillColor           = Color3.fromRGB(255, 0, 0)
   h.FillTransparency    = 0.6
   h.OutlineColor        = Color3.fromRGB(255, 30, 30)
   h.OutlineTransparency = 0
   h.Adornee             = model
   h.Parent              = model
end

local function removeHighlight(model)
   local h = model:FindFirstChild("CookieHighlight")
   if h then h:Destroy() end
end

local function isCookie(item)
   return item:IsA("Model") and string.find(item.Name, "Cookie")
end

local ToggleCookieEsp = ETab:CreateToggle({ -- CORRIGIDO: flag única, sem CreateToggle duplicado interno
   Name = "Cookie Esp",
   CurrentValue = false,
   Flag = "Toggle_CookieEsp",
   Callback = function(Value)
      if Value then
         espActive = true
         for _, item in ipairs(SpawnedItems_e:GetChildren()) do
            if isCookie(item) then applyHighlight(item) end
         end
         espConns[1] = SpawnedItems_e.ChildAdded:Connect(function(child)
            if espActive and isCookie(child) then
               task.wait(0.05)
               applyHighlight(child)
            end
         end)
         espConns[2] = SpawnedItems_e.ChildRemoved:Connect(function(child)
            if isCookie(child) then removeHighlight(child) end
         end)
      else
         espActive = false
         for _, conn in ipairs(espConns) do conn:Disconnect() end
         espConns = {}
         for _, item in ipairs(SpawnedItems_e:GetChildren()) do
            if isCookie(item) then removeHighlight(item) end
         end
      end
   end,
})

