-- =====================================================
-- CONFIGURAÇÃO
-- =====================================================
local KEYWORD              = "Cookie"
local HIGHLIGHT_COLOR      = Color3.fromRGB(255, 30, 30)  -- contorno vermelho
local FILL_COLOR           = Color3.fromRGB(255, 0, 0)    -- preenchimento vermelho
local FILL_TRANSPARENCY    = 0.6
local OUTLINE_TRANSPARENCY = 0
-- =====================================================

local isActive   = false
local loopThread = nil
local connections = {}  -- guarda conexões de ChildAdded/ChildRemoved

-- Caminho até SpawnedItems
local Map          = workspace:WaitForChild("Map")
local Functional   = Map:WaitForChild("Functional")
local SpawnedItems = Functional:WaitForChild("SpawnedItems")

-- =====================================================
-- HIGHLIGHT
-- =====================================================
local function applyHighlight(model)
	if model:FindFirstChild("CookieHighlight") then return end
	local h = Instance.new("Highlight")
	h.Name                = "CookieHighlight"
	h.FillColor           = FILL_COLOR
	h.FillTransparency    = FILL_TRANSPARENCY
	h.OutlineColor        = HIGHLIGHT_COLOR
	h.OutlineTransparency = OUTLINE_TRANSPARENCY
	h.Adornee             = model
	h.Parent              = model
end

local function removeHighlight(model)
	local h = model:FindFirstChild("CookieHighlight")
	if h then h:Destroy() end
end

local function isCookie(item)
	return item:IsA("Model") and string.find(item.Name, KEYWORD)
end

local function highlightAll()
	for _, item in ipairs(SpawnedItems:GetChildren()) do
		if isCookie(item) then
			applyHighlight(item)
		end
	end
end

local function removeAll()
	for _, item in ipairs(SpawnedItems:GetChildren()) do
		if isCookie(item) then
			removeHighlight(item)
		end
	end
end

-- =====================================================
-- START / STOP
-- =====================================================
local function startHighlight()
	isActive = true
	highlightAll()
	print("[CookieHighlight] 🔴 Ativado!")

	-- Detecta cookies que spawnarem depois
	connections[1] = SpawnedItems.ChildAdded:Connect(function(child)
		if isActive and isCookie(child) then
			task.wait(0.05)
			applyHighlight(child)
		end
	end)

	-- Remove highlight quando o cookie for coletado/destruído
	connections[2] = SpawnedItems.ChildRemoved:Connect(function(child)
		if isCookie(child) then
			removeHighlight(child)
		end
	end)
end

local function stopHighlight()
	isActive = false

	-- Desconecta os eventos
	for _, conn in ipairs(connections) do
		conn:Disconnect()
	end
	connections = {}

	removeAll()
	print("[CookieHighlight] ⚫ Desativado!")
end

