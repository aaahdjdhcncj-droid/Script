   CurrentValue = false,
   Flag = "Toggle_CookieEsp",
   Callback = function(Value)
      local SpawnedItems = getSpawnedItems()
      if not SpawnedItems then
         print("[CookieESP] âš ï¸ SpawnedItems nÃ£o encontrado!")
