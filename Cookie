-- Auto Cookies
local Players        = game:GetService("Players")
local player_main    = Players.LocalPlayer
local character_main = player_main.Character or player_main.CharacterAdded:Wait()
local rootPart_main  = character_main:WaitForChild("HumanoidRootPart")

local cookieActive   = false
local cookieThread   = nil

local Map_c          = workspace:WaitForChild("Map")
local Functional_c   = Map_c:WaitForChild("Functional")
local SpawnedItems_c = Functional_c:WaitForChild("SpawnedItems")

local function getCookies()
   local list = {}
   for _, item in ipairs(SpawnedItems_c:GetChildren()) do
      if item:IsA("Model") and string.find(item.Name, "CookieObject") then
         table.insert(list, item)
      end
   end
   return list
end

local function getPrompt(cookie)
   local prompt = cookie:FindFirstChildOfClass("ProximityPrompt")
   if prompt then return prompt end
   for _, child in ipairs(cookie:GetDescendants()) do
      if child:IsA("ProximityPrompt") then return child end
   end
   return nil
end

local function collectCookie(cookie)
   local prompt = getPrompt(cookie)
   if not prompt then return end
   local part = cookie.PrimaryPart or cookie:FindFirstChildOfClass("BasePart")
   if not part then return end
   local cf = rootPart_main.CFrame * CFrame.new(0, 0, -2)
   cookie:SetPrimaryPartCFrame(cf)
   task.wait(0.05)
   fireproximityprompt(prompt)
end

local ToggleAutoCookies = MTab:CreateToggle({ -- CORRIGIDO: flag única, variável única, sem CreateToggle duplicado interno
   Name = "Auto Cookies",
   CurrentValue = false,
   Flag = "Toggle_AutoCookies",
   Callback = function(Value)
      if Value then
         cookieActive = true
         cookieThread = task.spawn(function()
            while cookieActive do
               local cookies = getCookies()
               if #cookies == 0 then
                  task.wait(0.5)
               else
                  for _, cookie in ipairs(cookies) do
                     if not cookieActive then break end
                     collectCookie(cookie)
                     task.wait(0.1)
                  end
               end
            end
         end)
      else
         cookieActive = false
         if cookieThread then
            task.cancel(cookieThread)
            cookieThread = nil
         end
      end
   end,
})

player_main.CharacterAdded:Connect(function(newChar)
   if cookieActive then
      cookieActive = false
      if cookieThread then task.cancel(cookieThread) cookieThread = nil end
      ToggleAutoCookies:Set(false)
   end
   character_main = newChar
   rootPart_main  = newChar:WaitForChild("HumanoidRootPart")
end)

