local veiaActive = false
local veiaThread = nil

local function getGrandmaHead()
   local SpawnedNPCs = workspace:FindFirstChild("SpawnedNPCs")
   if not SpawnedNPCs then return nil end
   for _, item in ipairs(SpawnedNPCs:GetChildren()) do
      if item:IsA("Model") and string.find(item.Name, "Grandma") then
         local head = item:FindFirstChild("Head")
         if head then return head end
         return item.PrimaryPart or item:FindFirstChildOfClass("BasePart")
      end
   end
   return nil
end

local ToggleVeia = VTab:CreateToggle({
   Name = "Trollar a VovÃ³",
   CurrentValue = false,
   Flag = "Toggle_Veia",
   Callback = function(Value)
      if Value then
         local head = getGrandmaHead()
         if not head then
            print("[VovÃ³] âš ï¸ Grandma nÃ£o encontrada!")
            return
         end

         veiaActive = true
         veiaThread = task.spawn(function()
            while veiaActive do
               local char = player.Character
               local root = char and char:FindFirstChild("HumanoidRootPart")
               if root then
                  -- Busca a cabeÃ§a toda vez para seguir o movimento da vovÃ³
                  local currentHead = getGrandmaHead()
                  if currentHead then
                     -- Fica PARADO 8 metros acima da cabeÃ§a dela
                     -- Sem offset lateral â€” diretamente em cima
                     root.CFrame = CFrame.new(
                        currentHead.Position + Vector3.new(0, 8, 0)
                     )
                  end
               end
               task.wait(0.05)
            end
         end)
      else
         veiaActive = false
         if veiaThread then task.cancel(veiaThread) veiaThread = nil end
      end
   end,
})

player.CharacterAdded:Connect(function()
