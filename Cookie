local function getGrandma()
	for _, item in ipairs(SpawnedNPCs:GetChildren()) do
		if item:IsA("Model") and string.find(item.Name, KEYWORD) then
			return item
		end
	end
	return nil
end

local function getGrandmaCFrame()
	local grandma = getGrandma()
	if not grandma then return nil end

	local part = grandma.PrimaryPart or grandma:FindFirstChildOfClass("BasePart")
	if not part then return nil end

	return part.CFrame + OFFSET
end

-- =====================================================
-- LOOP
-- =====================================================
local function startLoop()
	local cf = getGrandmaCFrame()
	if not cf then
		print("[GrandmaTeleport] ⚠️ Grandma não encontrada em SpawnedNPCs!")
		return
	end

	isActive = true
	print("[GrandmaTeleport] ▶ Teleporte iniciado!")

	loopThread = task.spawn(function()
		while isActive do
			local target = getGrandmaCFrame()
			if target then
				rootPart.CFrame = target
			else
				print("[GrandmaTeleport] ⚠️ Grandma sumiu, aguardando...")
				task.wait(1)
			end
			task.wait(INTERVAL)
		end
	end)
end

local function stopLoop()
	isActive = false
	if loopThread then
		task.cancel(loopThread)
		loopThread = nil
	end
	print("[GrandmaTeleport] ⏹ Teleporte parado.")
end

