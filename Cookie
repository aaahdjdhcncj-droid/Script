      if item:IsA("Model") and string.find(item.Name, "Grandma") then
         local part = item.PrimaryPart or item:FindFirstChildOfClass("BasePart")
         if part then return part.CFrame + Vector3.new(0, 5, 0) end
      end
   end
   return nil
end

