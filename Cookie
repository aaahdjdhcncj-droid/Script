local Players = game:GetService("Players")

local player    = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid  = character:WaitForChild("Humanoid")
local backpack  = player:WaitForChild("Backpack")

-- =====================================================
-- CONFIGURAÇÃO
-- =====================================================
local INTERVAL = 0.08  -- segundos entre cada equip/unequip
-- =====================================================

local isLooping  = false
local loopThread = nil

local function getCurrentTool()
	for _, item in ipairs(character:GetChildren()) do
		if item:IsA("Tool") then return item end
	end
	return nil
end

local function getBackpackTool()
	return backpack:FindFirstChildOfClass("Tool")
end

local function startLoop()
	local tool = getCurrentTool() or getBackpackTool()
	if not tool then
		print("[ToggleTool] ⚠️ Nenhum Tool disponível!")
		return
	end

	isLooping = true
	print("[ToggleTool] ▶ Loop iniciado!")

	loopThread = task.spawn(function()
		while isLooping do
			if getCurrentTool() then
				humanoid:UnequipTools()
			else
				local toEquip = getBackpackTool()
				if toEquip then
					humanoid:EquipTool(toEquip)
				end
			end
			task.wait(INTERVAL)
		end
	end)
end

local function stopLoop()
	isLooping = false
	if loopThread then
		task.cancel(loopThread)
		loopThread = nil
	end
	humanoid:UnequipTools()
	print("[ToggleTool] ⏹ Loop parado.")
end

