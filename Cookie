   Flag = "Toggle_Veia",
   Callback = function(Value)
      if Value then
         local cf = getGrandmaCFrame()
         if not cf then
            print("[GrandmaTeleport] ⚠️ Grandma não encontrada!")
            return
         end
         veiaActive = true
         veiaThread = task.spawn(function()
            while veiaActive do
               local target = getGrandmaCFrame()
               if target then
                  rootPart_veia.CFrame = target
               else
                  task.wait(1)
               end
               task.wait(0.1)
            end
         end)
      else
         veiaActive = false
         if veiaThread then task.cancel(veiaThread) veiaThread = nil end
      end
   end,
})

