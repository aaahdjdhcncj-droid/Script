local Players        = game:GetService("Players")
local VirtualUser    = game:GetService("VirtualUser")

local player    = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local rootPart  = character:WaitForChild("HumanoidRootPart")

-- =====================================================
-- CONFIGURAÇÃO
-- =====================================================
local KEYWORD  = "CookieObject"  -- nome exato do modelo
local INTERVAL = 0.1             -- segundos entre cada cookie coletado
-- =====================================================

local isActive   = false
local loopThread = nil

-- Caminho até SpawnedItems
local Map          = workspace:WaitForChild("Map")
local Functional   = Map:WaitForChild("Functional")
local SpawnedItems = Functional:WaitForChild("SpawnedItems")

-- =====================================================
-- HELPERS
-- =====================================================
local function getCookies()
	local list = {}
	for _, item in ipairs(SpawnedItems:GetChildren()) do
		if item:IsA("Model") and string.find(item.Name, KEYWORD) then
			table.insert(list, item)
		end
	end
	return list
end

local function getPrompt(cookie)
	-- Procura ProximityPrompt direto no modelo ou nos filhos
	local prompt = cookie:FindFirstChildOfClass("ProximityPrompt")
	if prompt then return prompt end
	for _, child in ipairs(cookie:GetDescendants()) do
		if child:IsA("ProximityPrompt") then return child end
	end
	return nil
end

local function collectCookie(cookie)
	local prompt = getPrompt(cookie)
	if not prompt then return end

	-- Pega a parte principal do cookie para teleportar
	local part = cookie.PrimaryPart or cookie:FindFirstChildOfClass("BasePart")
	if not part then return end

	-- Teleporta o cookie para em cima do player
	local cf = rootPart.CFrame * CFrame.new(0, 0, -2)
	cookie:SetPrimaryPartCFrame(cf)

	-- Pequeno delay para o servidor registrar a posição
	task.wait(0.05)

	-- Aciona o ProximityPrompt
	fireproximityprompt(prompt)
end

-- =====================================================
-- LOOP
-- =====================================================
local function startLoop()
	isActive = true
	print("[CookieCollect] 🍪 Iniciado!")

	loopThread = task.spawn(function()
		while isActive do
			local cookies = getCookies()

			if #cookies == 0 then
				task.wait(0.5)  -- espera spawnar mais cookies
			else
				for _, cookie in ipairs(cookies) do
					if not isActive then break end
					collectCookie(cookie)
					task.wait(INTERVAL)
				end
			end
		end
	end)
end

local function stopLoop()
	isActive = false
	if loopThread then
		task.cancel(loopThread)
		loopThread = nil
	end
	print("[CookieCollect] ⏹ Parado!")
end

