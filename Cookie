-- ===================================================
-- KEY ESP â€” coloca Highlight em Tools com "Key" no nome
-- Varre: workspace inteiro, backpacks e personagens
-- ===================================================
local keyEspActive = false
local keyEspConns  = {}

local function applyKeyHighlight(obj)
   -- Aceita tanto a Tool em si quanto qualquer descendente/pai
   local tool = obj:IsA("Tool") and obj or nil
   if not tool then return end
   if not string.find(tool.Name, "Key") then return end
   if tool:FindFirstChild("_KeyESP") then return end

   local h = Instance.new("Highlight")
   h.Name                = "_KeyESP"
   h.FillColor           = Color3.fromRGB(255, 215, 0)   -- dourado
   h.FillTransparency    = 0.3
   h.OutlineColor        = Color3.fromRGB(255, 255, 255)
   h.OutlineTransparency = 0
   h.Adornee             = tool
   h.Parent              = tool
end

local function removeKeyHighlight(tool)
   if not tool:IsA("Tool") then return end
   local h = tool:FindFirstChild("_KeyESP")
   if h then h:Destroy() end
end

local function removeAllKeyHighlights()
   -- Varre tudo e remove highlights que criamos
   for _, obj in ipairs(workspace:GetDescendants()) do
      if obj.Name == "_KeyESP" and obj:IsA("Highlight") then
         obj:Destroy()
      end
   end
   for _, p in ipairs(Players:GetPlayers()) do
      local bp = p:FindFirstChild("Backpack")
      if bp then
         for _, obj in ipairs(bp:GetDescendants()) do
            if obj.Name == "_KeyESP" then obj:Destroy() end
         end
      end
   end
end

local function scanAllKeys()
   -- Workspace (ferramentas soltas no chÃ£o)
   for _, obj in ipairs(workspace:GetDescendants()) do
      if obj:IsA("Tool") and string.find(obj.Name, "Key") then
         applyKeyHighlight(obj)
      end
   end
   -- Backpacks e personagens de todos os players
   for _, p in ipairs(Players:GetPlayers()) do
      local bp = p:FindFirstChild("Backpack")
      if bp then
         for _, item in ipairs(bp:GetChildren()) do
            applyKeyHighlight(item)
         end
      end
      local char = p.Character
      if char then
         for _, item in ipairs(char:GetChildren()) do
            applyKeyHighlight(item)
         end
      end
   end
end

local ToggleKeyEsp = ETab:CreateToggle({
   Name = "Key ESP",
   CurrentValue = false,
   Flag = "Toggle_KeyEsp",
   Callback = function(Value)
      if Value then
         keyEspActive = true
         scanAllKeys()

         -- Detecta qualquer nova Tool adicionada no workspace
         keyEspConns[1] = workspace.DescendantAdded:Connect(function(obj)
            if keyEspActive and obj:IsA("Tool") and string.find(obj.Name, "Key") then
               task.wait(0.05)
               applyKeyHighlight(obj)
            end
         end)

         -- Detecta Tools removidas do workspace
         keyEspConns[2] = workspace.DescendantRemoving:Connect(function(obj)
            if obj:IsA("Tool") and string.find(obj.Name, "Key") then
               removeKeyHighlight(obj)
            end
         end)

         -- Detecta itens adicionados nas backpacks dos players jÃ¡ presentes
         for _, p in ipairs(Players:GetPlayers()) do
            local bp = p:FindFirstChild("Backpack")
            if bp then
               local c = bp.ChildAdded:Connect(function(item)
                  if keyEspActive then applyKeyHighlight(item) end
               end)
               table.insert(keyEspConns, c)
            end
         end

         -- Detecta novos players entrando
         keyEspConns[3] = Players.PlayerAdded:Connect(function(p)
            local bp = p:WaitForChild("Backpack")
            bp.ChildAdded:Connect(function(item)
               if keyEspActive then applyKeyHighlight(item) end
            end)
         end)

      else
         keyEspActive = false
         for _, conn in ipairs(keyEspConns) do conn:Disconnect() end
         keyEspConns = {}
         removeAllKeyHighlights()
      end
   end,
})

