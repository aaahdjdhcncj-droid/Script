local OTab = Window:CreateTab("Main", nil) -- Title, Image
local Section = OTab:CreateSection("Main")

local Toggle = OTab:CreateToggle({
   Name = "Auto Cut Trees",
   CurrentValue = false,
   Flag = "Toggle1", -- A flag is the identifier for the configuration file; make sure every element has a different flag if you're using configuration saving to ensure no overlaps
   Callback = function(Value)
   local Players = game:GetService("Players")
local itensFolder = workspace:WaitForChild("Itens")

local function teleportarItens(player)
	local character = player.Character or player.CharacterAdded:Wait()
	local rootPart = character:WaitForChild("HumanoidRootPart")

	for _, model in ipairs(itensFolder:GetChildren()) do
		if model:IsA("Model") then
			local primaryPart = model.PrimaryPart

			if primaryPart then
				model:SetPrimaryPartCFrame(rootPart.CFrame + Vector3.new(0, 2, 0))
			else
				-- Se o model não tiver PrimaryPart, move pelo primeiro BasePart encontrado
				local part = model:FindFirstChildWhichIsA("BasePart")
				if part then
					part.CFrame = rootPart.CFrame + Vector3.new(0, 2, 0)
				end
			end
		end
	end
end

-- Conecta a função ao evento de um jogador entrando
Players.PlayerAdded:Connect(function(player)
	teleportarItens(player)
end)

-- Caso queira teleportar para um jogador já presente (teste no Studio)
for _, player in ipairs(Players:GetPlayers()) do
	teleportarItens(player)
            end
   end,
})

