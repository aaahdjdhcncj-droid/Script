local Toggle = MTab:CreateToggle({
    Name = "God mode",
    CurrentValue = false,
    Flag = "MonsterAvoid",

    Callback = function(Value)
        _G.MonsterAvoid = Value

        if Value then
            task.spawn(function()
                local escondido = false
                local posicaoOriginal = nil
                local distancia = 25

                while _G.MonsterAvoid do
                    task.wait(0.1)

                    local player = game.Players.LocalPlayer
                    local character = player.Character
                    local hrp = character and character:FindFirstChild("HumanoidRootPart")

                    if not hrp then
                        continue
                    end

                    local monstroPerto = false

                    for _, nome in ipairs({"HeadMonster", "RobeMonster"}) do
                        local monstro = workspace:FindFirstChild(nome)

                        if monstro and monstro:IsA("Model") then
                            local parte = monstro.PrimaryPart or monstro:FindFirstChildWhichIsA("BasePart")

                            if parte then
                                local dist = (parte.Position - hrp.Position).Magnitude

                                if dist <= distancia then
                                    monstroPerto = true
                                    break
                                end
                            end
                        end
                    end

                    if monstroPerto and not escondido then
                        posicaoOriginal = hrp.CFrame
                        hrp.CFrame = hrp.CFrame - Vector3.new(0, 25, 0)
                        escondido = true

                    elseif not monstroPerto and escondido then
                        if posicaoOriginal then
                            hrp.CFrame = posicaoOriginal
                        end

                        escondido = false
                        posicaoOriginal = nil
                    end
                end
            end)
        end
    end,
})

