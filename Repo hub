		elseif item:IsA("Model") then
			local primaryPart = item.PrimaryPart or item:FindFirstChildWhichIsA("BasePart")
			if primaryPart then
				item:PivotTo(hrp.CFrame + Vector3.new(0, 5, 0))
			end
		end
	end
else
	warn("Pasta 'GeneratedItems' não encontrada!")
            end
   end,
})

local Toggle = MTab:CreateToggle({
    Name = "God Mode",
    CurrentValue = false,
    Flag = "MonsterAvoid",

    Callback = function(Value)
        _G.MonsterAvoid = Value

        if Value then
            task.spawn(function()
                local escondido = false
                local posicaoOriginal

                while _G.MonsterAvoid do
                    task.wait(0.1)

                    local player = game.Players.LocalPlayer
                    local character = player.Character
                    local hrp = character and character:FindFirstChild("HumanoidRootPart")

                    if not hrp then
                        continue
                    end

                    local menorDistancia = math.huge

                    for _, nome in ipairs({"HeadMonster", "RobeMonster"}) do
                        local monstro = workspace:FindFirstChild(nome)

                        if monstro and monstro:IsA("Model") then
                            local parte = monstro.PrimaryPart or monstro:FindFirstChildWhichIsA("BasePart")

                            if parte then
                                local ponto = escondido and posicaoOriginal.Position or hrp.Position
                                local dist = (parte.Position - ponto).Magnitude

                                if dist < menorDistancia then
                                    menorDistancia = dist
                                end
                            end
                        end
                    end

                    -- Esconde quando chegar a 25 studs
                    if not escondido and menorDistancia <= 25 then
                        posicaoOriginal = hrp.CFrame
                        hrp.CFrame = hrp.CFrame - Vector3.new(0, 25, 0)
                        escondido = true

                    -- Volta quando estiver a mais de 17 studs da posição original
                    elseif escondido and menorDistancia > 17 then
                        hrp.CFrame = posicaoOriginal
                        escondido = false
                        posicaoOriginal = nil
                    end
                end
            end)
        end
    end,
})

