local Toggle = CTab:CreateToggle({
    Name = "Fly",
    CurrentValue = false,
    Flag = "FlyMobile",

    Callback = function(Value)
        _G.FlyMobile = Value

        if Value then
            task.spawn(function()
                local Player = game.Players.LocalPlayer
                local Character = Player.Character or Player.CharacterAdded:Wait()
                local Humanoid = Character:WaitForChild("Humanoid")
                local HRP = Character:WaitForChild("HumanoidRootPart")

                local Vertical = 0

                local ScreenGui = Instance.new("ScreenGui")
                ScreenGui.Name = "FlyGui"
                ScreenGui.ResetOnSpawn = false
                ScreenGui.Parent = Player.PlayerGui

                local Up = Instance.new("TextButton")
                Up.Size = UDim2.new(0, 80, 0, 80)
                Up.Position = UDim2.new(1, -90, 0.6, -90)
                Up.Text = "↑"
                Up.Parent = ScreenGui

                local Down = Instance.new("TextButton")
                Down.Size = UDim2.new(0, 80, 0, 80)
                Down.Position = UDim2.new(1, -90, 0.6, 0)
                Down.Text = "↓"
                Down.Parent = ScreenGui

                Up.MouseButton1Down:Connect(function()
                    Vertical = 1
                end)

                Up.MouseButton1Up:Connect(function()
                    Vertical = 0
                end)

                Down.MouseButton1Down:Connect(function()
                    Vertical = -1
                end)

                Down.MouseButton1Up:Connect(function()
                    Vertical = 0
                end)

                local BV = Instance.new("BodyVelocity")
                BV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                BV.Parent = HRP

                while _G.FlyMobile and Character.Parent do
                    task.wait()

                    BV.Velocity =
                        (Humanoid.MoveDirection * 60) +
                        Vector3.new(0, Vertical * 60, 0)
                end

                BV:Destroy()

                if ScreenGui then
                    ScreenGui:Destroy()
                end
            end)
        end
    end,
})

