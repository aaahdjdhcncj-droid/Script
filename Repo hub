local Toggle = CTab:CreateToggle({
   Name = "Noclip",
   CurrentValue = false,
   Flag = "Toggle1", -- A flag is the identifier for the configuration file; make sure every element has a different flag if you're using configuration saving to ensure no overlaps
   Callback = function(Value)
local NoClip = false
local NoClipConnection

        NoClip = Value

        if NoClip then
            NoClipConnection = game:GetService("RunService").Stepped:Connect(function()
                local Character = game.Players.LocalPlayer.Character
                if Character then
                    for _, Part in pairs(Character:GetDescendants()) do
                        if Part:IsA("BasePart") and Part.Name ~= "HumanoidRootPart" then
                            -- Ignora o chão (CanCollide só desativa nas partes aéreas)
                            Part.CanCollide = false
                        end
                    end

                    -- Mantém o chão colidindo (HumanoidRootPart controla física do personagem)
                    local Root = Character:FindFirstChild("HumanoidRootPart")
                    if Root then
                        Root.CanCollide = false -- false aqui é necessário para mover, mas...
                    end

                    -- Mantém colisão com o chão via Humanoid
                    local Humanoid = Character:FindFirstChildOfClass("Humanoid")
                    if Humanoid then
                        Humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
                        Humanoid:SetStateEnabled(Enum.HumanoidStateType.Landed, true)
                    end
                end
            end)
        else
            -- Desativa o noclip e restaura colisões
            if NoClipConnection then
                NoClipConnection:Disconnect()
                NoClipConnection = nil
            end

            local Character = game.Players.LocalPlayer.Character
            if Character then
                for _, Part in pairs(Character:GetDescendants()) do
                    if Part:IsA("BasePart") then
                        Part.CanCollide = true
                    end
                end
            end
        end
    end,
})

